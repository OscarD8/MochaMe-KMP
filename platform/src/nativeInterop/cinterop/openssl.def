headers = openssl/evp.h
headerFilter = openssl/*
package = com.mochame.app.infrastructure.native.openssl

# Use pkg-config to automatically find paths
pkgConfig = openssl

compilerOpts.linux = -I/usr/include -I/usr/include/x86_64-linux-gnu
linkerOpts.linux = -L/usr/lib/x86_64-linux-gnu -lcrypto -lpthread -ldl